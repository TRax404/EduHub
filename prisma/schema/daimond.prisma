// ============================================================
//  DIAMOND WALLET
// ============================================================

model DiamondWallet {
    id String @id @default(cuid())

    studentProfileId String         @unique
    studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

    balance     Int @default(0)
    totalEarned Int @default(0)
    totalSpent  Int @default(0)

    // Optimistic locking — increment on every transaction
    // to prevent race conditions
    version Int @default(1)

    lastTransactionAt DateTime?

    transactions DiamondTransaction[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("diamond_wallets")
}

// ============================================================
//  DIAMOND TRANSACTION
// ============================================================

model DiamondTransaction {
    id String @id @default(cuid())

    walletId String
    wallet   DiamondWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

    // Positive = earn, Negative = spend
    amount Int

    // e.g. "QUIZ_REWARD", "STREAK_REWARD", "STORE_SPEND", "ADMIN_ADJUST"
    eventType String

    // e.g. "QUIZ", "EXAM", "REFERRAL", "ADMIN", "STORE"
    source String?

    // e.g. "quiz", "badge", "promo", "store"
    contextType String?

    // exact reference ID (quizId, promoCodeId, badgeId, etc.)
    contextId String?

    // Idempotency key — prevents duplicate transactions
    referenceId String @unique

    // Flexible metadata — store anything extra
    // e.g. { "quizTitle": "...", "score": 95, "bonusMultiplier": 1.5 }
    meta Json?

    note String?

    // Link to the event that triggered this transaction
    eventLogId String?
    eventLog   UserEventLog? @relation(fields: [eventLogId], references: [id])

    createdAt DateTime @default(now())

    @@index([walletId])
    @@index([eventType])
    @@index([source])
    @@index([contextType])
    @@index([createdAt])
    @@map("diamond_transactions")
}

// ============================================================
//  USER EVENT LOG
// ============================================================

model UserEventLog {
    id String @id @default(cuid())

    studentProfileId String
    studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

    // e.g. "QUIZ_COMPLETED", "EXAM_FINISHED", "REFERRAL_USED", "STREAK_ACHIEVED"
    eventType String

    // exact reference (quizId, examId, etc.)
    contextId String?

    // Flexible extra data
    // e.g. { "score": 88, "totalQuestions": 20, "timeTaken": 300 }
    meta Json?

    createdAt DateTime @default(now())

    // Transactions triggered by this event
    diamondTransactions DiamondTransaction[]

    @@index([studentProfileId])
    @@index([eventType])
    @@index([createdAt])
    @@map("user_event_logs")
}

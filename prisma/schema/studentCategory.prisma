model Category {
    id   String @id @default(cuid())
    name String
    slug String

    parentId String?
    parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
    children Category[] @relation("CategoryTree")

    type     CategoryType
    status   ContentStatus @default(TEST)
    isActive Boolean       @default(true)
    order    Int           @default(0)

    // Diamond unlock config
    // null মানে diamond দিয়ে unlock হবে না
    diamondUnlockCost Int?

    categoryPlans    CategoryPlan[]
    subscriptions    StudentSubscriptionCategory[]
    featureOverrides CategoryFeatureOverride[]
    diamondUnlocks   DiamondUnlock[]
    adminGrants      AdminGrant[]
    coupons          CouponCategory[] // কোন coupon এই category তে apply হয়

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([parentId, slug])
    @@index([parentId])
    @@index([type])
    @@index([status])
}

// Category ↔ Plan bridge
model CategoryPlan {
    id         String  @id @default(cuid())
    categoryId String
    planId     String
    isActive   Boolean @default(true)

    // Plan এর default price override করতে চাইলে
    priceOverride Float?

    category Category         @relation(fields: [categoryId], references: [id])
    plan     SubscriptionPlan @relation(fields: [planId], references: [id])

    @@unique([categoryId, planId])
}

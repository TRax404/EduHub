model StudentProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName       String
  lastName        String?
  avatarUrl       String?
  institutionName String?
  bio             String?
  referralCode    String  @unique

  classLevel   ClassLevel?
  studentGroup Group?
  targetExam   String?

  // Existing Gamification
  diamondWallet DiamondWallet?
  userBadges    UserBadge[]
  eventLogs     UserEventLog[]

  // Existing Performance
  totalWeightedScore     Float @default(0.0)
  totalWeightedQuestions Int   @default(0)
  globalSuccessRate      Float @default(0.0)

  // Existing Referral
  referredById String?
  referredBy   StudentProfile?  @relation("ReferralSystem", fields: [referredById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referrals    StudentProfile[] @relation("ReferralSystem")

  // Auth layer
  profileId String  @unique
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // ── NEW relations ──
  subscriptions  StudentSubscription[]
  progress       StudentProgress[]
  diamondUnlocks DiamondUnlock[] // diamond দিয়ে কী unlock করেছে
  adminGrants    AdminGrant[] // admin যা manually দিয়েছে
  couponUsages   CouponUsage[] // কোন coupon use করেছে
  payments       PaymentTransaction[]
}

enum ClassLevel {
  SIX
  SEVEN
  EIGHT
  SSC
  HSC
  HONOURS
}

enum Group {
  SCIENCE
  ARTS
  COMMERCE
  OTHER
}

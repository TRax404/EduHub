PORT=
FRONTEND_URL=


# Security
BCRYPT_SALT_ROUNDS=12

# Database
# DATABASE_URL=postgresql://myuser:mypassword@db:5432/nest_db_prod
DATABASE_URL=

# JWT Access
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=
# Optional; defaults to 900000 (15m). Should match JWT_ACCESS_EXPIRES_IN.
JWT_ACCESS_EXPIRES_MS=

# JWT Refresh
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=
# Optional; defaults to 604800000 (7d). Should match JWT_REFRESH_EXPIRES_IN.
JWT_REFRESH_EXPIRES_MS=
REFRESH_TOKEN_TTL_DAYS=

# Standard JWT Claims
JWT_ISSUER=
JWT_AUDIENCE=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# OTP (email verification + password reset)
OTP_TTL_SECONDS=60
OTP_MAX_ATTEMPTS=5


# ─────────────────────────────────────────────────────────────────────────────
# Redis (RedisService + BullMQ) — all credentials live here; same keys for app + workers
# ─────────────────────────────────────────────────────────────────────────────
# Use ONE of these patterns:
#   A) Full connection URL (recommended for Docker / cloud) — host, port, user, pass, db can be in the URL
#   B) REDIS_HOST + REDIS_PORT + REDIS_USERNAME + REDIS_PASSWORD + REDIS_DB (no URL)
#
# URL forms (examples only — replace with your values):
#   redis://:password@localhost:6379/0
#   redis://username:password@redis.example.com:6379/0
#   rediss://username:password@your-cloud-redis.example:6380/0   # TLS — set REDIS_TLS=true if not using rediss://
#
REDIS_URL=
# Legacy alias for the same value as REDIS_URL (optional if REDIS_URL is set)
REDIS_CONNECTION_URL=

# Standalone TCP (used when REDIS_URL and REDIS_CONNECTION_URL are empty)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# TLS for host/port mode: set to "true" when connecting with TLS (not required when using rediss:// in REDIS_URL)
REDIS_TLS=
# Default verifies server cert; set to "false" only with private CA / ElastiCache dev (BullMQ + ioredis)
REDIS_TLS_REJECT_UNAUTHORIZED=

# Logical key prefix in Redis (isolates this app in a shared instance)
REDIS_PREFIX=myapp

# Timeouts / in-process L1 cache (optional overrides)
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_LOCAL_CACHE_MAX=1000
REDIS_LOCAL_CACHE_TTL_MS=5000
REDIS_LOCK_ACQUIRE_MAX_WAIT_MS=2000

# Cluster (optional)
# REDIS_CLUSTER=true
# REDIS_CLUSTER_NODES=node1:6379,node2:6379,node3:6379

# Sentinel (optional — when set, host/port above are not used for discovery)
# REDIS_SENTINEL_HOST=
# REDIS_SENTINEL_PORT=26379
# REDIS_SENTINEL_MASTER=mymaster


